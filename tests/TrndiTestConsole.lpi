<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <PathDelim Value="\"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="TrndiTestConsole"/>
      <ResourceType Value="res"/>
    </General>
    <BuildModes>
      <Item Name="Default" Default="True"/>
    </BuildModes>
    <RequiredPackages>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="TrndiTestConsole.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="dexcom_time_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="dexcom_trend_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="tandem_trend_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="tandem_fixture_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="debug_intermit_test.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="api_general_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="api_dexcom_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="api_dexcom_new_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="api_xdrip_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="api_nightscout_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="api_nightscout3_tests.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="debug_firstx_dexcom_test.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="debug_firstx_tandem_test.pp"/>
        <IsPartOfProject Value="True"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <PathDelim Value="\"/>
    <Target>
      <Filename Value="TrndiTestConsole"/>
    </Target>
    <ConditionalDefines Value="TEST"/>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <Libraries Value="..\externals\quickjs\prebuilt\$(TargetCPU)-$(TargetOS)"/>
      <OtherUnitFiles Value="..\tests\mock;..\tests\testserver;..\units;..\units\misc\winutils;..\units\misc\winutils\directx;..\units\misc\nsutils;..\units\trndi\ext;..\units\forms;..\units\trndi\api;..\units\trndi;..\units\slicke;..\units\misc;..\units\misc\linutils;..\units\misc\razer;..\units\misc\razer\chroma"/>
      <UnitOutputDirectory Value="lib\$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Options>
        <Win32>
          <GraphicApplication Value="False"/>
        </Win32>
      </Options>
    </Linking>
    <Other>
      <CustomOptions Value="-B
-dTEST"/>
    </Other>
    <!-- ext_js_tests links the QuickJS engine and its ABI shim, so it is only
         compiled on the targets we ship prebuilt libraries for; elsewhere the
         runner leaves it out entirely. macOS has no committed libraries, so
         building the tests there needs externals/quickjs/build.sh mac first.
         Linux and macOS both need a runpath because the libraries are copied
         next to the binary, not installed. See externals/quickjs/README.md. -->
    <Conditionals Value="if ((TargetCPU='x86_64') and ((TargetOS='linux') or (TargetOS='win64'))) or (TargetOS='darwin') then CustomOptions += ' -dHAVE_QUICKJS';
if TargetOS='linux' then CustomOptions += ' -k-rpath=$ORIGIN';
if TargetOS='darwin' then CustomOptions += ' -k-rpath -k@loader_path';"/>
  </CompilerOptions>
</CONFIG>