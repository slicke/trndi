msgstr "Adresse muss mit http(s):// beginnen"

#: uwizard.wz_err_carelink_token
msgctxt "uwizard.wz_err_carelink_token"
msgid "The credential must be the captured CareLink token data (JSON, starting with \"{\")"
msgstr ""

#: uwizard.wz_err_email
msgctxt "uwizard.wz_err_email"
msgid "You must enter a valid e-mail address"
msgstr "Sie müssen eine gültige E-Mail-Adresse eingeben"

#: uwizard.wz_err_need_addr
msgctxt "uwizard.wz_err_need_addr"
msgid "Please enter a server address or username."
msgstr "Bitte geben Sie eine Serveradresse oder einen Benutzernamen ein."

#: uwizard.wz_err_password
msgctxt "uwizard.wz_err_password"
msgid "You must enter a password"
msgstr "Sie müssen ein Passwort eingeben"

#: uwizard.wz_err_thresh_hi
msgid "Please enter a valid high threshold (a number greater than zero)."
msgstr "Bitte geben Sie einen gültigen hohen Schwellenwert ein (eine Zahl größer als null)."

#: uwizard.wz_err_thresh_lo
msgid "Please enter a valid low threshold (a number greater than zero)."
msgstr "Bitte geben Sie einen gültigen niedrigen Schwellenwert ein (eine Zahl größer als null)."

#: uwizard.wz_err_thresh_order
msgid "The high threshold must be greater than the low threshold."
msgstr "Der hohe Schwellenwert muss größer als der niedrige Schwellenwert sein."

#: uwizard.wz_test_no_support
