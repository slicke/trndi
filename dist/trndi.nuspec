<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>trndi</id>
    <version>VERSION_PLACEHOLDER</version>
    <authors>Björn Lindh</authors>
    <owners>Björn Lindh</owners>
    <license type="expression">GPL-3.0-only</license>
    <projectUrl>https://github.com/slicke/trndi</projectUrl>
    <icon>icon.png</icon>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Trndi - Continuous Glucose Monitor (CGM) viewer for Windows. Monitor your blood glucose levels with support for Dexcom, Nightscout, Tandem Source, Medtronic CareLink, and xDrip+ data sources.</description>
    <summary>CGM viewer for Windows with extension support</summary>
    <releaseNotes>Automated build from GitHub Actions</releaseNotes>
    <copyright>Copyright 2026 Björn Lindh</copyright>
    <tags>diabetes glucose cgm dexcom nightscout xdrip tandem carelink monitoring health</tags>
  </metadata>
  <files>
    <file src="..\Trndi.exe" target="tools\Trndi.exe" />
    <file src="..\lang\**" target="tools\lang" />
    <file src="..\Trndi.png" target="icon.png" />
    <file src="chocolateyinstall.ps1" target="tools\chocolateyinstall.ps1" />
    <file src="chocolateyuninstall.ps1" target="tools\chocolateyuninstall.ps1" />
    <!-- CareLink login helper (sources only). Trndi.exe looks for it next to
         itself, i.e. tools\tools\carelink-login inside the package. -->
    <file src="..\tools\carelink-login\carelink-login.mjs" target="tools\tools\carelink-login\carelink-login.mjs" />
    <file src="..\tools\carelink-login\package.json" target="tools\tools\carelink-login\package.json" />
    <file src="..\tools\carelink-login\package-lock.json" target="tools\tools\carelink-login\package-lock.json" />
    <file src="..\tools\carelink-login\README.md" target="tools\tools\carelink-login\README.md" />
  </files>
</package>
