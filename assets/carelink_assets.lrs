LazarusResources.Add('carelink-login','MJS',[
  '#!/usr/bin/env node'#13#10'/*'#13#10' * Trndi '#226#128#148' Medtronic CareL'
  +'ink (Care Partner) login helper'#13#10' *'#13#10' * Copyright (c) Bj'#195
  +#182'rn Lindh '#226#128#148' https://github.com/slicke/trndi'#13#10' * Distr'
  +'ibuted under the GNU General Public License, Version 3.'#13#10' *'#13#10' *'
  +' Medtronic gates the CareLink login behind a CAPTCHA and only allows a'#13
  +#10' * mobile-app custom-scheme redirect (com.medtronic.carepartner:/sso), s'
  +'o the'#13#10' * authorization code can never be seen by a plain browser or '
  +'a headless'#13#10' * request. This helper opens a real browser window for y'
  +'ou to sign in, catches'#13#10' * the redirect the moment it happens, exchan'
  +'ges the code for tokens, and prints'#13#10' * the resulting token data (the'
  +' same JSON Trndi stores as its credential).'#13#10' *'#13#10' * It replaces'
  +' the older Python + Selenium + OpenSSL helper: the current'#13#10' * (Auth0'
  +') login needs none of that '#226#128#148' just Node and Puppeteer.'#13#10' '
  +'*'#13#10' * Usage:'#13#10' *   npm install          # once, pulls in Puppet'
  +'eer (bundles a browser)'#13#10' *   node carelink-login.mjs           # EU '
  +'/ rest-of-world (default)'#13#10' *   node carelink-login.mjs --us      # U'
  +'SA region'#13#10' *'#13#10' * The JSON blob is printed to stdout; all progr'
  +'ess/log text goes to stderr, so'#13#10' * you can also capture just the tok'
  +'en with:  node carelink-login.mjs > token.json'#13#10' *'#13#10' * Paste th'
  +'e printed JSON into Trndi''s CareLink credential field. Treat it like'#13#10
  +' * a password.'#13#10' */'#13#10#13#10'import puppeteer from ''puppeteer'';'
  +#13#10#13#10'// One discovery URL serves every region; the app uses this exa'
  +'ct Android UA.'#13#10'const DISCOVERY_URL = ''https://clcloud.minimed.eu/co'
  +'nnect/carepartner/v13/discover/android/3.6'';'#13#10'const ANDROID_UA = ''D'
  +'alvik/2.1.0 (Linux; U; Android 10; Nexus 5X Build/QQ3A.200805.001)'';'#13#10
  +'const LOGIN_TIMEOUT_MS = 5 * 60 * 1000; // 5 minutes to complete the browse'
  +'r login'#13#10#13#10'const region = process.argv.includes(''--us'') ? ''US'
  +''' : ''EU'';'#13#10#13#10'const log = (...a) => console.error(''[carelink-l'
  +'ogin]'', ...a);'#13#10#13#10'async function getJson(url) {'#13#10'  const r'
  +' = await fetch(url, { headers: { ''User-Agent'': ANDROID_UA, Accept: ''appl'
  +'ication/json'' } });'#13#10'  if (!r.ok) throw new Error(`GET ${url} -> HTT'
  +'P ${r.status}`);'#13#10'  return r.json();'#13#10'}'#13#10#13#10'/** Query '
  +'parameters of any URL, including non-http custom schemes. */'#13#10'functio'
  +'n queryParams(url) {'#13#10'  const i = url.indexOf(''?'');'#13#10'  const '
  +'q = i >= 0 ? url.slice(i + 1) : '''';'#13#10'  return new URLSearchParams(q'
  +'.split(''#'')[0]);'#13#10'}'#13#10#13#10'/** Resolve the region''s Auth0 lo'
  +'gin configuration from discovery + SSO config. */'#13#10'async function res'
  +'olveConfig() {'#13#10'  const disc = await getJson(DISCOVERY_URL);'#13#10' '
  +' const cp = (disc.CP || []).find((c) => String(c.region || '''').toUpperCas'
  +'e() === region);'#13#10'  if (!cp) throw new Error(`No CP entry for region '
  +'${region} in the discovery document`);'#13#10#13#10'  const ssoKey = cp.Use'
  +'SSOConfiguration;'#13#10'  const ssoUrl = cp[ssoKey];'#13#10'  if (!ssoUrl)'
  +' throw new Error(''Could not find the SSO configuration URL'');'#13#10#13#10
  +'  const sso = await getJson(ssoUrl);'#13#10'  const server = sso.server || '
  +'{};'#13#10'  let base = `https://${server.hostname}:${server.port || 443}`;'
  +#13#10'  if (server.prefix && server.prefix !== ''/'') base += ''/'' + serve'
  +'r.prefix;'#13#10#13#10'  const client = sso.client;'#13#10'  const ep = sso'
  +'.system_endpoints;'#13#10'  if (!client || !ep) {'#13#10'    throw new Erro'
  +'r('#13#10'      ''This region is not on the Auth0 login (no client/system_e'
  +'ndpoints in the SSO config). '' +'#13#10'      ''Only the Auth0 flow is sup'
  +'ported.'''#13#10'    );'#13#10'  }'#13#10#13#10'  return {'#13#10'    autho'
  +'rizeUrl: base + ep.authorization_endpoint_path,'#13#10'    tokenUrl: base +'
  +' ep.token_endpoint_path,'#13#10'    clientId: client.client_id,'#13#10'    '
  +'redirectUri: client.redirect_uri,'#13#10'    scope: client.scope,'#13#10'  '
  +'  audience: client.audience,'#13#10'  };'#13#10'}'#13#10#13#10'function bui'
  +'ldAuthorizeUrl(cfg, state) {'#13#10'  const p = new URLSearchParams({'#13#10
  +'    client_id: cfg.clientId,'#13#10'    response_type: ''code'','#13#10'   '
  +' scope: cfg.scope,'#13#10'    redirect_uri: cfg.redirectUri,'#13#10'    aud'
  +'ience: cfg.audience,'#13#10'    state,'#13#10'  });'#13#10'  return `${cfg.'
  +'authorizeUrl}?${p.toString()}`;'#13#10'}'#13#10#13#10'/**'#13#10' * Open a '
  +'browser to the authorize URL and resolve with the authorization code.'#13#10
  +' * The final step is a 302 to the custom-scheme redirect_uri; we catch it f'
  +'rom'#13#10' * either the response headers or the (blocked) navigation reque'
  +'st before the'#13#10' * browser gives up on the unknown scheme.'#13#10' */'
  ,#13#10'async function captureCode(cfg, authorizeUrl) {'#13#10'  const browse'
  +'r = await puppeteer.launch({'#13#10'    headless: false,'#13#10'    default'
  +'Viewport: null,'#13#10'    args: [''--no-sandbox'', ''--disable-blink-featu'
  +'res=AutomationControlled''],'#13#10'  });'#13#10#13#10'  try {'#13#10'    c'
  +'onst page = (await browser.pages())[0] || (await browser.newPage());'#13#10
  +#13#10'    return await new Promise((resolve, reject) => {'#13#10'      let '
  +'done = false;'#13#10'      const timer = setTimeout(() => finish(new Error('
  +'''Timed out waiting for login (5 minutes).'')), LOGIN_TIMEOUT_MS);'#13#10#13
  +#10'      function finish(err, value) {'#13#10'        if (done) return;'#13
  +#10'        done = true;'#13#10'        clearTimeout(timer);'#13#10'        '
  +'page.off(''response'', onResponse);'#13#10'        page.off(''request'', on'
  +'Request);'#13#10'        if (err) reject(err); else resolve(value);'#13#10
  +'      }'#13#10#13#10'      function tryUrl(u) {'#13#10'        if (!u || !u'
  +'.startsWith(cfg.redirectUri)) return false;'#13#10'        const params = q'
  +'ueryParams(u);'#13#10'        const code = params.get(''code'');'#13#10'   '
  +'     if (params.get(''error'')) {'#13#10'          finish(new Error(`Login '
  +'failed: ${params.get(''error_description'') || params.get(''error'')}`));'
  +#13#10'          return true;'#13#10'        }'#13#10'        if (code) {'#13
  +#10'          finish(null, { code, state: params.get(''state'') });'#13#10' '
  +'         return true;'#13#10'        }'#13#10'        return false;'#13#10
  +'      }'#13#10#13#10'      const onResponse = (resp) => {'#13#10'        co'
  +'nst s = resp.status();'#13#10'        if (s >= 300 && s < 400) tryUrl(resp.'
  +'headers().location || '''');'#13#10'      };'#13#10'      const onRequest ='
  +' (req) => { tryUrl(req.url()); };'#13#10#13#10'      page.on(''response'', '
  +'onResponse);'#13#10'      page.on(''request'', onRequest);'#13#10#13#10'   '
  +'   log(''opening browser '#226#128#148' sign in with your Care Partner acco'
  +'unt and solve the CAPTCHA'#226#128#166''');'#13#10'      // Navigation to t'
  +'he custom scheme rejects; that''s expected and handled above.'#13#10'      '
  +'page.goto(authorizeUrl, { waitUntil: ''domcontentloaded'' }).catch(() => {}'
  +');'#13#10'    });'#13#10'  } finally {'#13#10'    await browser.close().cat'
  +'ch(() => {});'#13#10'  }'#13#10'}'#13#10#13#10'async function exchangeCode('
  +'cfg, code) {'#13#10'  const body = new URLSearchParams({'#13#10'    grant_t'
  +'ype: ''authorization_code'','#13#10'    client_id: cfg.clientId,'#13#10'   '
  +' code,'#13#10'    redirect_uri: cfg.redirectUri,'#13#10'  });'#13#10'  cons'
  +'t r = await fetch(cfg.tokenUrl, {'#13#10'    method: ''POST'','#13#10'    h'
  +'eaders: { ''Content-Type'': ''application/x-www-form-urlencoded'', ''User-A'
  +'gent'': ANDROID_UA },'#13#10'    body: body.toString(),'#13#10'  });'#13#10
  +'  const text = await r.text();'#13#10'  if (!r.ok) throw new Error(`Token e'
  +'xchange failed: HTTP ${r.status} ${text}`);'#13#10'  return JSON.parse(text'
  +');'#13#10'}'#13#10#13#10'function randomState() {'#13#10'  return [...crypt'
  +'o.getRandomValues(new Uint8Array(16))].map((b) => b.toString(16).padStart(2'
  +', ''0'')).join('''');'#13#10'}'#13#10#13#10'async function main() {'#13#10
  +'  log(`region: ${region}${region === ''EU'' ? '' (use --us for the USA regi'
  +'on)'' : ''''}`);'#13#10#13#10'  const cfg = await resolveConfig();'#13#10' '
  +' const state = randomState();'#13#10'  const authorizeUrl = buildAuthorizeU'
  +'rl(cfg, state);'#13#10#13#10'  const { code, state: returnedState } = await'
  +' captureCode(cfg, authorizeUrl);'#13#10'  if (returnedState && returnedStat'
  +'e !== state) log(''warning: login state did not match (continuing anyway)'''
  +');'#13#10#13#10'  log(''got the login code, exchanging it for tokens'#226
  +#128#166''');'#13#10'  const tok = await exchangeCode(cfg, code);'#13#10#13
  +#10'  if (!tok.access_token || !tok.refresh_token) {'#13#10'    throw new Er'
  +'ror(''The token response did not contain access_token/refresh_token'');'#13
  +#10'  }'#13#10#13#10'  // The same shape as logindata.json / what Trndi stor'
  +'es as its credential.'#13#10'  const blob = {'#13#10'    access_token: tok.'
  +'access_token,'#13#10'    refresh_token: tok.refresh_token,'#13#10'    ...(t'
  +'ok.id_token ? { id_token: tok.id_token } : {}),'#13#10'    ...(tok.scope ? '
  +'{ scope: tok.scope } : {}),'#13#10'    client_id: cfg.clientId,'#13#10'  };'
  +#13#10#13#10'  // Only the JSON goes to stdout, so it can be piped or copied'
  +' cleanly.'#13#10'  console.log(JSON.stringify(blob, null, 2));'#13#10'  log'
  +'(''success '#226#128#148' copy the JSON above into Trndi\''s CareLink crede'
  +'ntial field. Treat it like a password.'');'#13#10'}'#13#10#13#10'main().cat'
  +'ch((e) => {'#13#10'  log(''ERROR:'', e.message || e);'#13#10'  process.exit'
  +'(1);'#13#10'});'#13#10
]);
