  +'gin": "carelink-login.mjs"'#13#10'  },'#13#10'  "scripts": {'#13#10'    "st'
  +'art": "node carelink-login.mjs",'#13#10'    "start:us": "node carelink-logi'
  +'n.mjs --us",'#13#10'    "start:eu": "node carelink-login.mjs"'#13#10'  },'
